# =============================================================================
# Root .dockerignore — Project Lenie
# All compose builds use project root as build context (context: ../..)
# Docker matching: patterns without ** match root level only
# =============================================================================

# Version control
.git/
.gitignore

# Python artifacts (any level)
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.coverage
**/.ruff_cache/

# Virtual environments
**/.venv/
backend/.venv_wsl/

# Node.js artifacts (any level)
**/node_modules/
**/.vite/
**/npm-debug.log
**/yarn-debug.log

# Build outputs (rebuilt inside Docker)
**/dist/
**/build/
**/out/

# IDE / editor
**/.idea/
**/.vscode/
**/*.swp
**/*.swo

# Environment and secrets (compose uses env_file from host, not context)
.env*
**/*.pem
**/*.key
**/*.crt

# Documentation and markdown
**/*.md
# IMPORTANT: Exceptions below MUST stay after **/*.md (Docker processes rules top-to-bottom)
# These README.md files are required by hatchling build (pyproject.toml readme field)
!slack_bot/README.md
!shared_python/unified-config-loader/README.md

# Project directories not needed in any Docker build
_bmad/
_bmad-output/
.claude/
docs/
scripts/
web_landing_page/
web_chrome_extension/
infra/

# Backend dev/test files (Dockerfile only copies library/ and server.py)
backend/tests/
backend/test_code/
backend/tmp/
backend/imports/
backend/data/

# CI/CD configs
.circleci/
.gitlab-ci.yml
Jenkinsfile
.pre-commit-config.yaml
Makefile

# Docker meta (Dockerfiles read from host via -f flag, not from context)
**/Dockerfile*
**/.dockerignore

# Misc
**/*.log
**/*.tmp
