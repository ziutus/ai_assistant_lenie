{
  "mcpServers": {
    "awslabs.aws-iac-mcp-server": {
      "disabled": false,
      "timeout": 180,
      "type": "stdio",
      "command": "awslabs.aws-iac-mcp-server",
      "args": [],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "default",
        "AWS_REGION": "eu-central-1"
      }
    },
    "awslabs.cfn-mcp-server": {
      "disabled": false,
      "timeout": 180,
      "type": "stdio",
      "command": "awslabs.cfn-mcp-server",
      "args": [
        "--readonly"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_PROFILE": "default",
        "AWS_REGION": "eu-central-1"
      }
    },
    "awslabs.aws-api-mcp-server": {
      "disabled": false,
      "timeout": 180,
      "type": "stdio",
      "command": "awslabs.aws-api-mcp-server",
      "args": [],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "READ_OPERATIONS_ONLY": "true",
        "AWS_PROFILE": "default",
        "AWS_REGION": "eu-central-1"
      }
    },
    "gitguardian": {
      "disabled": false,
      "timeout": 120,
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/GitGuardian/ggmcp.git",
        "developer-mcp-server"
      ]
    }
  }
}
