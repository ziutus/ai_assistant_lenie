# =============================================================================
# BOOTSTRAP VARIABLES (always required, regardless of backend)
# =============================================================================
# Backend: "env" (default, reads .env), "vault" (HashiCorp Vault), "aws" (SSM Parameter Store)
# When using "vault" or "aws" backend, only bootstrap variables below are needed in .env.
# All other variables are loaded from the selected backend at startup.
SECRETS_BACKEND="env"
# Environment name used in secret paths (dev/prod/qa)
SECRETS_ENV="dev"
# Project code used in secret paths (default: lenie)
# PROJECT_CODE="lenie"

# Vault backend only (required when SECRETS_BACKEND=vault)
# VAULT_ADDR="http://vault:8200"
# VAULT_TOKEN=""

# =============================================================================
# APPLICATION VARIABLES (required only when SECRETS_BACKEND=env)
# When using vault/aws backend, these are loaded from the secret store.
# =============================================================================
ENV_DATA=""
POSTGRESQL_HOST=""
POSTGRESQL_DATABASE=""
POSTGRESQL_USER=""
POSTGRESQL_PASSWORD=""
POSTGRESQL_PORT=""
BACKEND_TYPE=""
WEBSITES_CACHE_DIR=""
LINKS_CACHE_DIR=""
AWS_FREE_TIER_ACCESS_KEY_ID=""
AWS_FREE_TIER_SECRET_ACCESS_KEY=""
AWS_FREE_TIER_REGION=""
AWS_FREE_TIER_PROFILE=""
AWS_FREE_TIER_VPN_SERVER=''
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
AWS_S3_WEBSITE_CONTENT=""
OPENAI_API_KEY=""
OPENAI_ORGANIZATION=""
EMBEDDING_MODEL=""
USE_SSL=""
DEBUG=""
PORT=

STALKER_AWS_API_URL= ""
STALKER_AWS_API_KEY= ""