# =============================================================================
# Project Lenie — Bootstrap Environment Variables
# =============================================================================
#
# This file contains ONLY bootstrap variables needed to initialize the
# config_loader module. The actual application configuration is loaded
# from the selected secrets backend at startup.
#
# Three backends are available:
#   env   — All variables read from this .env file (default, for local dev)
#   vault — HashiCorp Vault KV v2 (Docker/NAS deployments)
#   aws   — AWS SSM Parameter Store (Lambda/cloud deployments)
#
# For full documentation see: docs/secrets-management.md
# For variable reference see: scripts/vars-classification.yaml
#
# =============================================================================

# --- Backend Selection (used by all backends: env, vault, aws) ---
# Which secret backend to use: "env", "vault", or "aws"
SECRETS_BACKEND="env"

# Environment name used in secret paths (dev | prod | qa) — used by all backends
SECRETS_ENV="dev"

# Project code used in secret paths (default: lenie) — used by all backends
# PROJECT_CODE="lenie"

# Date of last configuration data update, logged at startup — used by all backends
ENV_DATA=""

# --- Vault Backend (required only when SECRETS_BACKEND=vault) ---
# VAULT_ADDR="http://vault.local:8200"
# VAULT_TOKEN=""

# --- AWS Backend (required only when SECRETS_BACKEND=aws) ---
# Default AWS region for SDK calls
# AWS_REGION="eu-central-1"

# =============================================================================
# NOTE: For SECRETS_BACKEND=env, generate a full .env with all application
# variables using:
#   python scripts/env_to_vault.py generate env-example --backend env --output .env
#
# This reads variable definitions from scripts/vars-classification.yaml (SSOT).
# =============================================================================
