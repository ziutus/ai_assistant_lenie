# =============================================================================
# Project Lenie — NAS Docker Deployment (.env for Vault backend)
# =============================================================================
#
# This file contains ONLY bootstrap variables. All application secrets
# (database credentials, API keys, LLM settings, etc.) are loaded from
# HashiCorp Vault at startup by the config_loader module.
#
# Setup:
#   1. Copy this file to nas.env:  cp nas.env.example nas.env
#   2. Fill in VAULT_TOKEN with a valid Vault token
#   3. Update ENV_DATA with the current date
#   4. Ensure Vault has secrets at: secret/lenie/dev
#      (upload with: python scripts/env_to_vault.py vault upload --env dev --write)
#
# For full documentation see: docs/security/secrets-management.md
# For variable reference see: scripts/vars-classification.yaml
# =============================================================================

# --- Backend Selection ---
SECRETS_BACKEND=vault

# Environment name used in Vault secret path (dev | prod | qa)
SECRETS_ENV=dev

# Project code used in Vault secret path — secret/{PROJECT_CODE}/{SECRETS_ENV}
# PROJECT_CODE=lenie

# Date of last configuration data update, logged at startup
ENV_DATA=2026.02.27

# --- Vault Connection ---
VAULT_ADDR=http://lenie-vault:8200
VAULT_TOKEN=<your-vault-token>

# --- Slack Bot ---
SLACK_BOT_TOKEN=<xoxb-your-slack-bot-token>
SLACK_APP_TOKEN=<xapp-your-slack-app-token>
SLACK_CHANNEL_STARTUP=#general

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=lenie-admin
MINIO_ROOT_PASSWORD=<your-minio-password>
S3_ENDPOINT_URL=http://lenie-minio:9000
