# syntax=docker/dockerfile:1.7
# MCP Server Dockerfile — build context must be project root
# Build: docker build -f infra/docker/Dockerfile.mcp -t lenie-mcp-server .

FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 PYTHONDONTWRITEBYTECODE=1 PYTHONPATH=/app

# Set the working directory in the container
WORKDIR /app

# Install curl (required for healthcheck)
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:0.9.9 /uv /uvx /bin/

# Copy shared package first (path dependency)
COPY shared_python/unified-config-loader/ /shared_python/unified-config-loader/

# Copy dependency files
COPY backend/pyproject.toml backend/uv.lock ./

# Install dependencies — base deps only (mcp>=1.0 is in base; no --extra docker needed)
RUN uv sync --frozen --no-dev --no-install-project

# Copy MCP server modules (exclude tests — only production source)
COPY backend/library ./library/
COPY backend/mcp_server/__init__.py ./mcp_server/
COPY backend/mcp_server/main.py ./mcp_server/
COPY backend/mcp_server/errors.py ./mcp_server/
COPY backend/mcp_server/path_security.py ./mcp_server/
COPY backend/mcp_server/tools ./mcp_server/tools/

# Create a non-root user with specific UID and GID, and change ownership of the app directory
RUN groupadd -g 1000 lenie-ai-client && \
    useradd -u 1000 -g lenie-ai-client -m lenie-ai-client && \
    chown -R 1000:1000 /app

# Switch to the lenie-ai-client user
USER lenie-ai-client

# Expose port 8080 for the MCP server
EXPOSE 8080

# Entry point: uvicorn serving the Starlette ASGI app from mcp_server.main
ENTRYPOINT ["/app/.venv/bin/uvicorn", "mcp_server.main:app", "--host", "0.0.0.0", "--port", "8080"]
