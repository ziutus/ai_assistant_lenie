# AWS credentials for Vault auto-unseal via KMS
# Created by CloudFormation stack: lenie-nas-vault-kms-unseal
# Account: personal (ziutus-Administrator profile), Region: eu-central-1
#
# Copy this file to the NAS:
#   scp infra/docker/vault.env admin@192.168.200.7:/share/Container/lenie-env/vault.env
# Then fill in the real values from CloudFormation stack outputs.

AWS_ACCESS_KEY_ID=<your-vault-kms-access-key>
AWS_SECRET_ACCESS_KEY=<your-vault-kms-secret-key>
AWS_REGION=eu-central-1
