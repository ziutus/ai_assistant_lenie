PYTHON_VERSION=3.11
PYTHON_VERSION_NICE=3_11
PROFILE="default"
PLATFORM="manylinux2014_x86_64"
PROJECT_NAME="lenie"
ENVIRONMENT="dev"
AWS_ACCOUNT_ID="<your-aws-account-id>"
AWS_LAMBDA_DEFAULT_ROLE="arn:aws:iam::<your-aws-account-id>:role/<your-lambda-execution-role>"
AWS_S3_BUCKET_NAME="${PROJECT_NAME}-${ENVIRONMENT}-cloudformation"
